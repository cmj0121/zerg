# requires: v0.7

fn main() {
    ch := chan[int]()
    spawn fn() {
        ch <- 1
        ch <- 2
        ch <- 3
    }()
    a := <- ch
    b := <- ch
    c := <- ch
    match a {
        Option.Some(v) => print v
        Option.None => print -1
    }
    match b {
        Option.Some(v) => print v
        Option.None => print -1
    }
    match c {
        Option.Some(v) => print v
        Option.None => print -1
    }
}

main()
