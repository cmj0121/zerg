# requires: v0.8
import "strings"

fn classify(s: str) {
    match strings.parse_int(s) {
        Result.Ok(_) => print "ok"
        Result.Err(e) => match e {
            ParseError.Empty => print "Empty"
            ParseError.InvalidDigit => print "InvalidDigit"
            ParseError.Overflow => print "Overflow"
        }
    }
}

classify("99999999999999999999999")
classify("-99999999999999999999999")
classify("9223372036854775808")
classify("-9223372036854775809")
