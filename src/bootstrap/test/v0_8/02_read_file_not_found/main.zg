# requires: v0.8
import "io"
import "os"
import "strings"

match os.env("ZERG_TEST_TEMPDIR") {
    Option.Some(d) => {
        path := strings.join([d, "missing.txt"], "/")
        match io.read_file(path) {
            Result.Ok(_) => print "ok?"
            Result.Err(e) => match e {
                IoError.NotFound => print "not found"
                IoError.PermissionDenied => print "permission denied"
                IoError.AlreadyExists => print "already exists"
                IoError.InvalidPath => print "invalid path"
                IoError.Other => print "other"
            }
        }
    }
    Option.None => print "no tempdir"
}
