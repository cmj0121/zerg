# requires: v0.7

fn main() {
    ch := chan[int]()
    spawn fn() {
        ch <- 1
        ch <- 2
        ch <- 3
    }()
    a := <- ch
    b := <- ch
    c := <- ch
    match a {
        v => print v
        nil => print -1
    }
    match b {
        v => print v
        nil => print -1
    }
    match c {
        v => print v
        nil => print -1
    }
}

main()
