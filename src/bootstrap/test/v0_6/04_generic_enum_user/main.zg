# requires: v0.6

enum Pair[A, B] {
    Both(A, B),
    Left(A),
    Right(B)
}

let p: Pair[int, str] = Pair.Both(7, "hi")
match p {
    Pair.Both(a, b) => {
        print a
        print b
    }
    Pair.Left(a) => print a
    Pair.Right(b) => print b
}

fn make_left() -> Pair[int, str] {
    return Pair.Left(3)
}
fn make_right() -> Pair[int, str] {
    return Pair.Right("hello")
}

let q := make_left()
match q {
    Pair.Both(a, b) => {
        print a
        print b
    }
    Pair.Left(a) => print a
    Pair.Right(b) => print b
}

let r := make_right()
match r {
    Pair.Both(a, b) => {
        print a
        print b
    }
    Pair.Left(a) => print a
    Pair.Right(b) => print b
}
