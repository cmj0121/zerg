# requires: v0.8
import "io"
import "os"
import "strings"

match os.env("ZERG_TEST_TEMPDIR") {
    d => {
        path := strings.join([d, "input.txt"], "/")
        match io.read_file(path) {
            Result.Ok(content) => print strings.trim(content)
            Result.Err(_) => print "read err"
        }
    }
    nil => print "no tempdir"
}
