# requires: v0.7

fn main() {
    ch := chan[int](1)
    wg := wait_group()
    wg.add(2)
    spawn fn() {
        ch <- 11
        wg.done()
    }()
    spawn fn() {
        ch <- 22
        wg.done()
    }()
    a := <- ch
    b := <- ch
    wg.wait()
    match a {
        v => print v
        nil => print -1
    }
    match b {
        v => print v
        nil => print -1
    }
}

main()
