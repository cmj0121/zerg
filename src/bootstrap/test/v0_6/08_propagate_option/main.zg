# requires: v0.6

fn first_even(xs: list[int]) -> int? {
    for x in xs {
        if x % 2 == 0 {
            return x
        }
    }
    return nil
}

fn double_first_even(xs: list[int]) -> int? {
    let v := first_even(xs)?
    return v * 2
}

print double_first_even([1, 4, 5])
print double_first_even([1, 3, 5])
print double_first_even([2, 4, 6])
