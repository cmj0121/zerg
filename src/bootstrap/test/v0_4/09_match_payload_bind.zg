enum Token {
    Eof,
    Ident(str),
    Number(int, str)
}

t := Token.Ident("hello")
match t {
    Token.Eof => print "eof"
    Token.Ident(name) => print name
    Token.Number(value, base) => print value
}

n := Token.Number(42, "dec")
match n {
    Token.Eof => print "eof"
    Token.Ident(name) => print name
    Token.Number(value, base) => print value
}
