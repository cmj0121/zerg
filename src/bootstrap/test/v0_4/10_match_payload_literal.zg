enum Token {
    Number(int, str),
    Eof
}

let zero := Token.Number(0, "zero")
let other := Token.Number(7, "seven")

match zero {
    Token.Number(0, _) => print "zero literal"
    Token.Number(n, s) => print n
    Token.Eof => print "eof"
}
match other {
    Token.Number(0, _) => print "zero literal"
    Token.Number(n, s) => print n
    Token.Eof => print "eof"
}
