struct Point { x: int, y: int }
enum Color { Red, Green, Blue }

fn describe(p: Point, c: Color) -> str {
    let pair := (clone(p), clone(c))
    match pair {
        (Point { x: 0, y: 0 }, Color.Red) => return "origin red"
        (Point { x: 0, .. }, Color.Green) => return "y-axis green"
        (Point { x, y }, Color.Blue) => return "blue elsewhere"
        (Point { x, y }, c) => return "fallback"
    }
    return "unreachable"
}

print describe(Point { x: 0, y: 0 }, Color.Red)
print describe(Point { x: 0, y: 5 }, Color.Green)
print describe(Point { x: 1, y: 1 }, Color.Blue)
print describe(Point { x: 2, y: 3 }, Color.Red)
