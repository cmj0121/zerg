# requires: v0.14
#
# sys/syscall round-trip: write "hi\n" to stdout via the raw `write`
# trap, branch on the returned byte count, and exit through the raw
# `exit` trap. The expected.txt + exit-code-0 invariants together pin:
#   - write actually writes 3 bytes to fd 1
#   - the mut-int output operand surfaces the kernel's x0 into Zerg
#   - sys.syscall.exit terminates cleanly with the chosen status
import "sys/syscall"

msg: list[byte] = ['h', 'i', '\n']
n := syscall.write(1, msg, 3)
if n != 3 {
	syscall.exit(1)
}
syscall.exit(0)
