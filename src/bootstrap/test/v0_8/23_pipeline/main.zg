# requires: v0.8
import "std/io"
import "std/os"
import "std/strings"

fn sum_lines(content: str) -> int {
    lines := strings.split(strings.trim(content), ",")
    mut total := 0
    for line in lines {
        match strings.parse_int(strings.trim(line)) {
            Result.Ok(n) => total = total + n
            Result.Err(_) => print "skipped"
        }
    }
    return total
}

match os.env("ZERG_TEST_TEMPDIR") {
    Option.Some(d) => {
        path := strings.join([d, "numbers.txt"], "/")
        match io.read_file(path) {
            Result.Ok(content) => print sum_lines(content)
            Result.Err(_) => print "read err"
        }
    }
    Option.None => print "no tempdir"
}
