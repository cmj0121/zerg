# requires: v0.6

none_inner: Option[int] = Option.None
x: Option[Option[int]] = Option.Some(Option.Some(7))
y: Option[Option[int]] = Option.Some(none_inner)
z: Option[Option[int]] = Option.None
print x
print y
print z

inner_ok: Result[str, int] = Result.Ok("inner-ok")
inner_err: Result[str, int] = Result.Err(404)
r1: Result[int, Result[str, int]] = Result.Ok(1)
r2: Result[int, Result[str, int]] = Result.Err(inner_ok)
r3: Result[int, Result[str, int]] = Result.Err(inner_err)
print r1
print r2
print r3
