# requires: v0.6

fn parse(input: str) -> Result[int, str] {
    if input == "good" {
        return Result.Ok(42)
    }
    return Result.Err("bad input")
}

fn process(input: str) -> Result[int, str] {
    v := parse(input)?
    return Result.Ok(v + 1)
}

print process("good")
print process("nope")
